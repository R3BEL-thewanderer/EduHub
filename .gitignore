credentials.json

# ================================
# Heavy Files (PDFs, Notes)
# ================================
# Ignore the local notes folder so you don't push hundreds of MBs of PDFs to GitHub!
# (GitHub has file size limits and it will crash your upload if you upload all PDFs)
notes/
file_list.txt
test_url.py
upload_notes.py
verify_upload.py

